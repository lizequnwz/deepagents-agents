  "cards": [
    {
      "dot": "cyan",
      "title": "Source isolation",
      "items": [
        "A conversation is permanently bound to one registered source",
        "The source fixes OSI, dialect, limits, backend target, and result scope"
      ]
    },
    {
      "dot": "rose",
      "title": "Reviewed SQL, constrained charts",
      "items": [
        "Every SQL execution pauses before database access",
        "Explicit chart requests auto-run only a validated declarative spec",
        "Result provenance cannot change and arbitrary Python never executes"
      ]
    },
    {
      "dot": "emerald",
      "title": "Plug-and-play visualization",
      "items": [
        "Explicit requests route one saved result to the optional specialist",
        "One generic ChartSpec covers common charts without arbitrary Python",
        "Disabling the feature leaves text-to-SQL behavior unchanged"
      ]
    }
  ]
