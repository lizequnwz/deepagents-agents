# Required
OPENAI_API_KEY=your_openai_api_key_here

# Application defaults
OPENAI_MODEL=gpt-5.4-mini
DATA_SOURCES_CONFIG=data_sources.yaml
API_BASE_URL=http://127.0.0.1:8000
APP_BASE_URL=http://127.0.0.1:8501
SQL_TIMEOUT_SECONDS=10
SQL_MAX_RESULT_ROWS=500
MODEL_SAMPLE_ROWS=10
ENABLE_DATA_VISUALIZATION=true

# Per-user-run execution budgets
COORDINATOR_MODEL_CALL_LIMIT=12
COORDINATOR_TOOL_CALL_LIMIT=12
COORDINATOR_TASK_CALL_LIMIT=4
SQL_AGENT_MODEL_CALL_LIMIT=24
SQL_AGENT_TOOL_CALL_LIMIT=30
SQL_EXECUTE_CALL_LIMIT=3
VISUALIZATION_AGENT_MODEL_CALL_LIMIT=12
VISUALIZATION_AGENT_TOOL_CALL_LIMIT=16

# Include bounded tool payloads in failed-run diagnostics.
AGENT_DEBUG_DETAILS=false

# Optional location for the cached US postal dataset used by ZIP/city maps.
# PGEOCODE_DATA_DIR=/tmp/pgeocode_data

# Optional LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=data-analytics-agent
