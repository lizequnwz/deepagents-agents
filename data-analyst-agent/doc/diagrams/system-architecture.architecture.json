  "cards": [
    {
      "dot": "cyan",
      "title": "Source isolation",
      "items": [
        "A conversation is permanently bound to one registered source",
        "The selected source fixes the OSI path, SQL dialect, limits, and backend target"
      ]
    },
    {
      "dot": "rose",
      "title": "Safety boundary",
      "items": [
        "Exactly one read-only query is structurally validated",
        "Every execution pauses for approve, edit, or reject",
        "Backend-native controls remain the final enforcement layer"
      ]
    },
    {
      "dot": "emerald",
      "title": "Extension seams",
      "items": [
        "New databases implement SQLBackend without changing the agent contract",
        "New specialist agents use explicit task and artifact contracts"
      ]
